# exo — environment config
# Copy to .env and edit.

# === LLM routing ===
# exo's LLM router picks per-actor based on actor.model in domain.yaml.
# These are the catalogs of available backends. At least one must be configured.

# --- Claude OAuth (frontier, via Claude Code) ---
# No env var needed if you have Claude Code installed; the runner shells out
# to `claude` for actors with model: "claude-oauth".

# --- Ollama Cloud (frontier OSS via API) ---
OLLAMA_CLOUD_API_KEY=
# OLLAMA_CLOUD_BASE_URL=https://api.ollama.com/v1

# --- Local Ollama or compatible (llama-swap / BERTHA / vLLM) ---
LOCAL_OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
# LOCAL_OLLAMA_BASE_URL=http://host.docker.internal:1234/v1   # llama-swap default
LOCAL_OLLAMA_API_KEY=ollama

# --- Embeddings (used for vector memory tier) ---
EMBEDDING_BASE_URL=http://host.docker.internal:11434/v1
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSIONS=768
# For higher-quality embeddings (if you run qwen3-embedding-4b on BERTHA):
# EMBEDDING_BASE_URL=http://host.docker.internal:1234/v1
# EMBEDDING_MODEL=embed
# EMBEDDING_DIMENSIONS=2560

# === Infrastructure (defaults set in compose.yaml) ===
NEO4J_USER=neo4j
NEO4J_PASSWORD=exo-local-only
POSTGRES_PASSWORD=exo-local-only

# === Runner ===
EXO_LOG_LEVEL=INFO
EXO_MAX_PARALLEL_AGENTS=4
EXO_DEFAULT_LLM_TIMEOUT=120
