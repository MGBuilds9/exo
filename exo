#!/usr/bin/env python3
"""exo — multi-agent simulation engine CLI.

Usage:
  exo architect [--name NAME] [--out DIR]
  exo run <domain.yaml> [--scenario PATH] [--rounds N] [--out DIR]
  exo report <run_dir>
  exo --version

Run `exo COMMAND --help` for command-specific options.
"""
from __future__ import annotations

import sys
from pathlib import Path

# UTF-8 stdout/stderr on Windows
try:
    sys.stdout.reconfigure(encoding="utf-8", errors="replace")
    sys.stderr.reconfigure(encoding="utf-8", errors="replace")
except (AttributeError, OSError):
    pass

ROOT = Path(__file__).resolve().parent
sys.path.insert(0, str(ROOT))

import click

from cli import architect_cmd, run_cmd, report_cmd, doctor_cmd, solve_cmd, recommend_cmd, execute_cmd, memory_cmd, plan_cmd

VERSION = "0.1.0"


@click.group(help="exo — multi-agent simulation engine.")
@click.version_option(VERSION)
def main() -> None:
    pass


@main.command("architect")
@click.option("--name", default=None, help="Working name for the simulation (kebab-case).")
@click.option("--out", type=click.Path(), default=None, help="Output directory (default: ./<name>/).")
@click.option("--non-interactive", is_flag=True, help="Use defaults; skip questions.")
def architect_command(name: str | None, out: str | None, non_interactive: bool) -> None:
    """Walk through 12 questions to design a new multi-agent simulation."""
    architect_cmd.run(name=name, out_dir=out, non_interactive=non_interactive)


@main.command("run")
@click.argument("domain_yaml", type=click.Path(exists=True))
@click.option("--scenario", type=click.Path(exists=True), default=None, help="scenario.yaml (defaults to ./scenario.yaml next to domain).")
@click.option("--rounds", type=int, default=None, help="Override turn count from scenario.")
@click.option("--out", type=click.Path(), default=None, help="Output directory for transcript + report.")
def run_command(domain_yaml: str, scenario: str | None, rounds: int | None, out: str | None) -> None:
    """Run a simulation defined by a domain.yaml."""
    run_cmd.run(domain_path=domain_yaml, scenario_path=scenario, rounds_override=rounds, out_dir=out)


@main.command("report")
@click.argument("run_dir", type=click.Path(exists=True))
def report_command(run_dir: str) -> None:
    """Generate a human-readable summary of a completed run."""
    report_cmd.run(run_dir=run_dir)


@main.command("doctor")
@click.option("--host", "extra_hosts", multiple=True, help="Additional host(s) to probe (e.g., your homelab IP). Repeatable.")
@click.option("--json", "as_json", is_flag=True, help="Emit machine-readable JSON instead of pretty output.")
def doctor_command(extra_hosts: tuple[str, ...], as_json: bool) -> None:
    """Scan local hardware + services + cloud accounts; recommend a personalized stack."""
    doctor_cmd.run(extra_hosts=list(extra_hosts), as_json=as_json)


@main.command("solve")
@click.argument("source_path", type=click.Path(exists=True))
@click.option("--top", "top_n", type=int, default=5, help="Number of top issues to plan for.")
@click.option("--out", "out_dir", type=click.Path(), default=None, help="Output directory for the plan markdown.")
@click.option("--non-interactive", is_flag=True, help="Skip clarifying-question prompts; just produce the plan.")
@click.option("--no-recommend", is_flag=True, help="Skip the auto-invocation of `exo recommend` for capability hints.")
def solve_command(source_path: str, top_n: int, out_dir: str | None,
                  non_interactive: bool, no_recommend: bool) -> None:
    """Read a data source, identify issues, propose action plan."""
    solve_cmd.run(source_path=source_path, top_n=top_n, out_dir=out_dir,
                  interactive=not non_interactive, invoke_recommend=not no_recommend)


@main.command("recommend")
@click.argument("capability")
@click.option("--license", "license_constraint",
              type=click.Choice(["any", "permissive", "no-agpl", "no-copyleft"]),
              default="any", help="License constraint for candidates.")
@click.option("--weight-profile",
              type=click.Choice(["default", "reliable", "cutting-edge", "commercial"]),
              default="default", help="Scoring weights.")
@click.option("--json", "as_json", is_flag=True, help="Emit machine-readable JSON.")
@click.option("--out", "out_dir", type=click.Path(), default=None, help="Persist a snapshot of the ranking.")
def recommend_command(capability: str, license_constraint: str, weight_profile: str,
                      as_json: bool, out_dir: str | None) -> None:
    """Score and rank candidate repos for a capability using live GitHub data.

    Use 'list' as the capability to see all available capability slugs.
    """
    recommend_cmd.run(capability=capability, license_constraint=license_constraint,
                      weight_profile=weight_profile, as_json=as_json, out_dir=out_dir)


@main.command("execute")
@click.argument("plan_path", type=click.Path(exists=True))
@click.option("--out", "out_dir", type=click.Path(), default=None, help="Output directory for the session record.")
@click.option("--auto", is_flag=True, help="Auto-run SAFE commands without prompting (CAUTION/DESTRUCTIVE still gated).")
@click.option("--allow-caution", is_flag=True, help="With --auto, also auto-run CAUTION-class commands.")
@click.option("--max-steps", type=int, default=10, help="Maximum number of steps to walk in this session.")
@click.option("--replay", "replay_fixture", type=click.Path(exists=True), default=None,
              help="Replay synthetic command outputs from a YAML fixture. Nothing actually runs.")
def execute_command(plan_path: str, out_dir: str | None,
                    auto: bool, allow_caution: bool, max_steps: int,
                    replay_fixture: str | None) -> None:
    """Walk a solve plan with consent gates. Safe-by-default; destructive ops double-confirmed."""
    execute_cmd.run(plan_path=plan_path, out_dir=out_dir,
                    auto=auto, allow_caution=allow_caution, max_steps=max_steps,
                    replay_fixture=replay_fixture)


main.add_command(memory_cmd.memory)


@main.command("plan")
@click.argument("fleet_path", type=click.Path(exists=True))
@click.option("--strategy", type=click.Choice(["balanced", "specialized", "consolidated"]),
              default="specialized")
@click.option("--out", "out_dir", type=click.Path(), default=None,
              help="Output dir for the plan markdown.")
@click.option("--steps-per-wave", type=int, default=3,
              help="How many moves to batch per migration wave.")
def plan_command(fleet_path: str, strategy: str, out_dir: str | None,
                 steps_per_wave: int) -> None:
    """Rebalance a fleet description. Reads hosts + workloads + constraints,
    produces a target placement + risk-ordered migration plan."""
    plan_cmd.run(fleet_path=fleet_path, strategy=strategy,
                 out_dir=out_dir, steps_per_wave=steps_per_wave)


if __name__ == "__main__":
    main()
